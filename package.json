{
    "name": "hippocampus",
    "version": "0.1.0",
    "description": "A schema-free semantic memory system for intelligent agents",
    "main": "dist/index.js",
    "pkg": {
        "scripts": "dist/**/*.js",
        "assets": [
            "dist/proto/hippocampus.proto",
            "node_modules/@xenova/transformers/**/*",
            "node_modules/better-sqlite3/build/**/*"
        ],
        "targets": [
            "node22-linux-x64",
            "node22-win-x64"
        ],
        "outputPath": "release"
    },
    "scripts": {
        "build": "tsc && node -e \"require('fs').cpSync('src/proto', 'dist/proto', {recursive:true})\"",
        "server": "node dist/server/index.js",
        "pkg:linux": "node scripts/patch-for-pkg.js && pkg dist/server/index.js --target node22-linux-x64 --output release/hippocampus-server-linux --compress GZip && bash scripts/pkg-fix.sh release/hippocampus-server-linux linux",
        "pkg:win": "node scripts/patch-for-pkg.js && pkg dist/server/index.js --target node22-win-x64 --output release/hippocampus-server-win.exe --compress GZip && bash scripts/pkg-fix.sh release/hippocampus-server-win.exe win",
        "pkg:all": "npm run pkg:linux && npm run pkg:win",
        "release:linux": "npm run build && npm run pkg:linux && bash installer/scripts/build-appimage.sh",
        "release:win": "npm run build && npm run pkg:win && bash installer/scripts/build-nsis.sh",
        "docker:up": "docker compose up -d --build",
        "docker:down": "docker compose down",
        "docker:logs": "docker compose logs -f hippocampus",
        "docker:ingest": "docker compose -f docker-compose.yml -f docker-compose.cli.yml run --rm hippocampus",
        "docker:setup": "docker compose --profile setup up ollama-pull",
        "ingest": "ts-node src/cli/cli.ts ingest",
        "ingest-dir": "ts-node src/cli/cli.ts ingest-dir",
        "watch": "ts-node src/cli/cli.ts watch",
        "query": "ts-node src/cli/cli.ts query",
        "query-answer": "ts-node src/cli/cli.ts query-answer",
        "consolidate": "ts-node src/cli/cli.ts consolidate",
        "concepts": "ts-node src/cli/cli.ts concepts",
        "dev": "ts-node src/cli/cli.ts",
        "server:dev": "ts-node src/server/index.ts",
        "test": "ts-node src/tests/integration.test.ts",
        "benchmark": "ts-node src/cli/cli.ts benchmark",
        "overview": "ts-node src/cli/cli.ts overview",
        "start": "node dist/cli/cli.js"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.12.6",
        "@grpc/proto-loader": "^0.7.13",
        "@qdrant/js-client-rest": "^1.9.0",
        "@tensorflow/tfjs-node": "^4.20.0",
        "@xenova/transformers": "^2.17.2",
        "better-sqlite3": "^9.4.3",
        "busboy": "^1.6.0",
        "cheerio": "^1.2.0",
        "chokidar": "^5.0.0",
        "fastify": "^4.26.2",
        "mammoth": "^1.7.1",
        "ollama": "^0.6.3",
        "p-queue": "^8.0.1",
        "pdf-parse": "^1.1.1",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.8",
        "@types/busboy": "^1.5.4",
        "@types/cheerio": "^0.22.35",
        "@types/node": "^20.11.5",
        "@types/pdf-parse": "^1.1.4",
        "@types/uuid": "^9.0.7",
        "@yao-pkg/pkg": "^5.16.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    },
    "keywords": [
        "memory",
        "semantic-search",
        "rag",
        "vector-db",
        "llm"
    ],
    "license": "MIT"
}