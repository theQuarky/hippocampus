---
interface NavItem {
  label: string;
  href: string;
}

interface NavGroup {
  title: string;
  items: NavItem[];
}

const groups: NavGroup[] = [
  {
    title: 'Getting Started',
    items: [
      { label: 'Quickstart', href: '/hippocampus/docs/quickstart' },
      { label: 'Docker Setup', href: '/hippocampus/docs/docker' },
    ],
  },
  {
    title: 'Usage',
    items: [
      { label: 'CLI Reference', href: '/hippocampus/docs/cli' },
      { label: 'HTTP API', href: '/hippocampus/docs/api' },
      { label: 'Configuration', href: '/hippocampus/docs/configuration' },
    ],
  },
  {
    title: 'Internals',
    items: [
      { label: 'Architecture', href: '/hippocampus/docs/architecture' },
    ],
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
---

<aside id="docs-sidebar" class="docs-sidebar hidden lg:block w-64 shrink-0">
  <nav class="sticky top-20 pr-4 max-h-[calc(100vh-5rem)] overflow-y-auto">
    {groups.map(group => (
      <div class="mb-6">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-text-dim mb-2 px-3">
          {group.title}
        </h4>
        <ul class="space-y-0.5">
          {group.items.map(item => {
            const isActive = currentPath === item.href || currentPath === item.href + '/';
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'block px-3 py-1.5 text-sm rounded-md transition-colors',
                    isActive
                      ? 'text-text-primary bg-bg-panel border-l-2 border-accent font-medium'
                      : 'text-text-muted hover:text-text-primary hover:bg-bg-panel',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<!-- Mobile sidebar overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>

<style>
  @media (max-width: 1023px) {
    .docs-sidebar.open {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 50;
      width: 280px;
      padding: 1rem;
      background: #0f1117;
      border-right: 1px solid #2a2d36;
      overflow-y: auto;
    }
  }
</style>
